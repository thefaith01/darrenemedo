# Copy to .env.local for local development. This file is the canonical list
# of environment variables (same convention as SureStep's .env.example).
#
# Both variables are SERVER-SIDE ONLY — never expose the service key to the
# browser. When absent, the contact form runs in demo mode: submissions are
# logged to the server console and a success response is returned.

# Supabase project URL (Settings -> API)
SUPABASE_URL=

# Supabase service role key (Settings -> API). Server-side only.
SUPABASE_SERVICE_KEY=
